	cd /d D:\MYPROJ~1\bustub\BUILD~1.COD\src\primer && $(CMAKE_COMMAND) -P CMakeFiles\bustub_primer.dir\cmake_clean.cmake
.PHONY : src/primer/CMakeFiles/bustub_primer.dir/clean

src/primer/CMakeFiles/bustub_primer.dir/depend:
	$(CMAKE_COMMAND) -E cmake_depends "MinGW Makefiles" "D:\my project\bustub" "D:\my project\bustub\src\primer" "D:\my project\bustub\build.codex" "D:\my project\bustub\build.codex\src\primer" "D:\my project\bustub\build.codex\src\primer\CMakeFiles\bustub_primer.dir\DependInfo.cmake" "--color=$(COLOR)" bustub_primer
.PHONY : src/primer/CMakeFiles/bustub_primer.dir/depend

